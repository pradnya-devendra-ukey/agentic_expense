# ── REQUIRED ──────────────────────────────────────────────────────────────────
# OpenAI API Key for agent planning, query generation, and information extraction
OPENAI_API_KEY=your-openai-api-key-here

# ── OPTIONAL CONFIGURATION ───────────────────────────────────────────────────
# SQLite database path (default: expenses.db)
DB_PATH=expenses.db

# LLM model choice (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# JWT Secret for encrypting auth tokens (change this in production!)
JWT_SECRET=pennywise-super-secret-jwt-key-change-me

# ── DATABASE PERSISTENCE FOR DEPLOYMENT (POSTGRESQL) ─────────────────────────
# When set, the application uses PostgreSQL (e.g., Neon).
# If left empty, it falls back to a local SQLite database (expenses.db).
DATABASE_URL=

# ── VOICE INTEGRATION (OPTIONAL) ─────────────────────────────────────────────
# Deepgram API Key for voice recording transcription
DEEPGRAM_API_KEY=
